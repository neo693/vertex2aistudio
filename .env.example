# Port the proxy server will listen on
PORT=8080

# Google AI Studio API Key (Gemini API Key)
# Generate yours at https://aistudio.google.com/
GEMINI_API_KEY=your_google_ai_studio_api_key_here

# Target Google AI Studio API version (default: v1beta)
TARGET_API_VERSION=v1beta

# Custom model mapping overrides (format: vertex_model:ai_studio_model,...)
# Example: my-custom-model:gemini-1.5-pro
MODEL_MAPPINGS=

# Set to true to disable wildcard CORS headers (default: false)
DISABLE_CORS=false
