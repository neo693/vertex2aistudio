# Port the proxy server will listen on
PORT=8080

# Google Cloud Vertex AI API Key
# Generated in Google Cloud Console under APIs & Services > Credentials
VERTEX_API_KEY=your_vertex_api_key_here

# Target Google Cloud Project ID (Required)
VERTEX_PROJECT_ID=your_gcp_project_id_here

# Target Google Cloud Region (default: us-central1)
VERTEX_REGION=us-central1

# Custom Vertex API endpoint override (Optional, e.g. for testing)
VERTEX_API_ENDPOINT=

# Custom model mapping overrides (format: aistudio_model:vertex_model,...)
# Example: gemini-1.5-pro:gemini-1.5-pro-001
MODEL_MAPPINGS=

# Set to true to disable wildcard CORS headers (default: false)
DISABLE_CORS=false
